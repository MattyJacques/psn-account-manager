{
  "manifest_version": 3,
  "name": "PSN Account Manager",
  "version": "1.0.0",
  "description": "Keep track of your PlayStation Network accounts.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PSN Account Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "clipboardWrite", "tabs", "scripting", "declarativeNetRequestWithHostAccess", "cookies"],
  "host_permissions": ["https://www.playstation.com/*", "https://my.account.sony.com/*", "https://ca.account.sony.com/*"],
  "background": {
    "service_worker": "background.js"
  }
}
